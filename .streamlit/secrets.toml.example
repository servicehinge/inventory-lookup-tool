# 複製成 secrets.toml（本機）或貼進 Streamlit Cloud → App → Settings → Secrets。
# 切勿 commit 真正的 secrets.toml（.gitignore 已排除）。

HUBSPOT_API_TOKEN = "pat-na1-xxxxxxxx"

# 進站密碼（決定身分）：員工密碼→內部完整版；經銷商密碼→經銷商版（台灣全藏）
STAFF_PASSWORD = "員工密碼"
DEALER_PASSWORD = "經銷商密碼"

# 美國表 + 台灣表共用的 Google service account（與 shipping-quote 同一把）
[gcp_service_account]
type = "service_account"
project_id = "shipping-quote-486901"
private_key_id = "xxxx"
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "shipping-quote-bot@shipping-quote-486901.iam.gserviceaccount.com"
client_id = "xxxx"
token_uri = "https://oauth2.googleapis.com/token"
